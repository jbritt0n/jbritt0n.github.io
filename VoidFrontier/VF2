function checkGroundCombatEnd(){
  const st=groundCombatState;if(!st||st.phase!=='active')return;
  if(st.enemies.every(e=>e.hp<=0)){
    st.phase='victory';const cr=st.enemies.reduce((s,e)=>{const l=e.loot?.cr||[10,40];return s+Math.floor(l[0]+Math.random()*(l[1]-l[0]));},0);const sc=st.enemies.reduce((s,e)=>s+(e.loot?.scrap||0),0);
    G.flagship.credits+=cr;G.flagship.scrap=(G.flagship.scrap||0)+sc;
    // Sync HP back
    st.party.forEach(p=>{const c=G.crew.find(x=>x.id===p.id);if(c)c.hp=Math.max(1,p.hp);});
    G.crew.filter(c=>c.alive).forEach(c=>{c.xp=(c.xp||0)+15;checkCrewLevelUp(c);});
    st.log.unshift(`★ VICTORY ★ +${cr} CR, +${sc} scrap`);renderGroundCombat();setTimeout(closeGroundCombat,1400);
