function setTarget(id){if(G.combat?.enemy.systems[id]?.hp>0){combatTarget=id;renderCombat();}}
function combatAction(action){
  const c=G.combat,s=G.flagship,e=c.enemy;if(!c||c.won)return;
  const wb=getStationBonus('weapons'),sb=getStationBonus('shields'),eb=getStationBonus('engines');
  // Apply hazard accuracy mod
  const accMod=c.hazardAccMod||0;
  if(action==='fire'){
    if(!combatTarget){addCombatLog('Select a target system first!');return;}
    if(c.playerSys.weapons.hp<=0){addCombatLog('Weapons offline!');return;}
    if(c.hazardWeaponsDisabled){addCombatLog('Weapons knocked offline this turn!');c.hazardWeaponsDisabled=false;return;}
    const base=12+Math.floor(G.rng.next()*15)+wb;const boost=G.flagship.modules.includes('plasma_injector')?1.4:1.0;const dmg=Math.floor(base*boost);
    const hitChance=0.9+accMod;
    if(G.rng.next()<hitChance){
      const tgt=e.systems[combatTarget];tgt.hp=Math.max(0,tgt.hp-dmg);addCombatLog(`${s.name} fires on ${tgt.name} — ${dmg} dmg!`,'player');
      if(tgt.hp<=0)addCombatLog(`${tgt.name} DESTROYED!`,'player');
      const splash=Math.floor(dmg*0.3);if(e.shield>0){const sd=Math.min(e.shield,splash);e.shield-=sd;}else{e.hull=Math.max(0,e.hull-splash);}
    }else addCombatLog('Shot missed!','player');
    c.hazardAccMod=0;
  }else if(action==='special'){
    if(c.specialUsed){addCombatLog('Special on cooldown (3 rounds).');return;}
    if(!combatTarget){addCombatLog('Select a target!');return;}
    const dmg=20+wb*3;const tgt=e.systems[combatTarget];tgt.hp=Math.max(0,tgt.hp-dmg);e.hull=Math.max(0,e.hull-Math.floor(dmg*0.5));
    c.specialUsed=true;addCombatLog(`💥 Special shot hits ${tgt.name} for ${dmg}! Hull bleed ${Math.floor(dmg*0.5)}.`,'player');
  }else if(action==='boost_shields'){const regen=15+sb;s.shields=Math.min(s.maxShields,s.shields+regen);addCombatLog(`Shields boosted +${regen}.`,'player');
  }else if(action==='evasive'){c.evasionActive=true;s.fuel=Math.max(0,s.fuel-5);addCombatLog(`Evasive maneuvers! Fuel -5. Evade+${25+eb}%.`,'player');
  }else if(action==='flee'){
    if(s.fuel<15){addCombatLog('Not enough fuel!');return;}
    const fleeChance=0.5+(eb*0.03);
    if(G.rng.next()<fleeChance){addCombatLog('Emergency FTL! Escaped.','player');s.fuel-=15;exitCombat(false);return;}
    else addCombatLog('Flee failed!','player');
  }
  // Hazard check
  if(!c.hazardCooldown&&G.rng.next()<0.13)triggerCombatHazard();else if(c.hazardCooldown>0)c.hazardCooldown--;
  // Special shot cooldown recovery
  if(c.round>0&&c.round%3===0)c.specialUsed=false;
  // Enemy attack turn
  if(e.systems.weapons.hp>0){
    const evade=c.evasionActive?0.35+eb*0.02:0.7;
    if(G.rng.next()<evade){
      const eDmg=8+Math.floor(G.rng.next()*12);
      if(s.shields>0){const sd=Math.min(s.shields,eDmg);s.shields-=sd;const spill=Math.max(0,eDmg-sd);if(spill>0)s.hull=Math.max(0,s.hull-spill);addCombatLog(`Enemy hits shields -${sd}${spill>0?' hull -'+spill:''}!`,'enemy');}
      else{s.hull=Math.max(0,s.hull-eDmg);addCombatLog(`Enemy hits hull -${eDmg}!`,'enemy');}
      // AI Assistant
      if(G.flagship.modules.includes('ai_assistant')&&G.rng.next()<0.3){const sys=Object.values(c.playerSys).find(v=>v.hp<v.maxHp);if(sys){sys.hp=Math.min(sys.maxHp,sys.hp+8);addCombatLog('AI repairs '+sys.name,'system');}}
    }else addCombatLog('Enemy missed!','enemy');
  }else addCombatLog('Enemy weapons offline — cannot fire.','system');
  c.evasionActive=false;c.round++;
  if(s.hull<=0){triggerGameOver();return;}
  if(e.hull<=0){c.won=true;addCombatLog('VICTORY! Enemy ship destroyed.','player');setTimeout(()=>exitCombat(true),800);return;}
  renderCombat();
}
function triggerCombatHazard(){
  const c=G.combat,h=COMBAT_HAZARDS[Math.floor(G.rng.next()*COMBAT_HAZARDS.length)];c.hazardCooldown=4;
  const bar=document.getElementById('cbat-hazard-bar');bar.innerHTML=`<div class="hazard-alert">⚠ ${h.title}: ${h.desc}</div>`;setTimeout(()=>{if(bar)bar.innerHTML='';},3500);
