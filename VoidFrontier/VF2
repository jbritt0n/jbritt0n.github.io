function startGroundCombat(ctx={}){
  const count=1+Math.floor(G.rng.next()*2);const enemies=[];
  for(let i=0;i<count;i++){const e=generateGroundEnemy();enemies.push({...e,id:e.id+'_'+i});}
  const party=G.crew.filter(c=>c.alive&&c.hp>0).slice(0,4).map(c=>({...c,ap:4,maxAp:4,tookTurn:false}));
  if(!party.length){addLog('No crew available!');showScreen('galaxy-screen');return;}
  groundCombatState={phase:'active',party,enemies,log:['⚔ Ground combat begins!'],acting:party[0]?.id||null,selectedEnemy:enemies[0]?.id||null,round:1,ctx};
  showScreen('ground-combat-screen');renderGroundCombat();
}
function getCrewMoves(c){
  const cls=CLASSES.find(x=>x.id===c.classId);if(!cls)return[];
  const moves=[...cls.groundMoves];const t2=c.advancedClass?TIER2_CLASSES[c.advancedClass]:null;
  if(t2?.newMove)moves.push(t2.newMove);return moves;
}
function executeGroundAction(moveId){
  const st=groundCombatState;if(!st||st.phase!=='active'||!st.acting)return;
  const actor=st.party.find(p=>p.id===st.acting);if(!actor||actor.hp<=0)return;
  const ap=actor.ap||0;
  if(moveId==='basic_attack'){
    if(ap<1)return;
    const tgt=st.enemies.find(e=>e.id===st.selectedEnemy&&e.hp>0)||st.enemies.find(e=>e.hp>0);if(!tgt){addLog('No target!');return;}
    const dmg=Math.max(1,Math.floor((actor.atk||8)*(0.9+Math.random()*0.3)));tgt.hp=Math.max(0,tgt.hp-dmg);
    st.log.unshift(`${actor.name} attacks ${tgt.name} for ${dmg}!`);actor.ap-=1;
  }else{
    const moves=getCrewMoves(actor),move=moves.find(m=>m.id===moveId);if(!move||ap<move.cost){return;}
    actor.ap-=move.cost;const tgt=st.enemies.find(e=>e.id===st.selectedEnemy&&e.hp>0)||st.enemies.find(e=>e.hp>0);
    // Execute move
    if(move.dmgMult&&tgt){const dmg=Math.floor((actor.atk||8)*move.dmgMult*(0.9+Math.random()*0.2));tgt.hp=Math.max(0,tgt.hp-dmg);st.log.unshift(`${actor.name} uses ${move.name} for ${dmg}!`);if(move.stunChance&&Math.random()<move.stunChance){tgt.status='stunned';st.log.unshift(`${tgt.name} stunned!`);}if(move.aoe){st.enemies.filter(e=>e.hp>0&&e.id!==tgt.id).forEach(e=>{const ad=Math.floor(dmg*0.5);e.hp=Math.max(0,e.hp-ad);});st.log.unshift('AOE splash!');}}
    if(move.heal){const target=st.party.filter(p=>p.hp>0).sort((a,b)=>a.hp/a.maxHp-b.hp/b.maxHp)[0]||actor;const h=Math.floor((move.heal||10)+(actor.skill||5)*0.5);target.hp=Math.min(target.maxHp,target.hp+h);st.log.unshift(`${actor.name} heals ${target.name} for ${h}!`);}
    if(move.aoeHeal){st.party.filter(p=>p.hp>0).forEach(p=>{p.hp=Math.min(p.maxHp,p.hp+Math.floor(move.aoeHeal||10));});st.log.unshift(`${actor.name} heals all allies!`);}
    if(move.confuse&&tgt){tgt.status='confused';st.log.unshift(`${tgt.name} is confused!`);}
    if(move.reviveAlly){const ko=st.party.find(p=>p.hp<=0);if(ko){ko.hp=Math.floor(ko.maxHp*0.25);st.log.unshift(`${actor.name} revives ${ko.name}!`);}}
    if(move.reviveAll){st.party.filter(p=>p.hp<=0).forEach(p=>{p.hp=Math.floor(p.maxHp*0.15);});st.log.unshift(`${actor.name} revives ALL fallen allies!`);}
    if(move.stealth){st.party.forEach(p=>{p.stealthed=2;});st.log.unshift('Party enters stealth!');}
    if(move.disable&&tgt){tgt.disabled=2;st.log.unshift(`${tgt.name} is disabled!`);}
    if(!move.dmgMult&&!move.heal&&!move.aoeHeal)st.log.unshift(`${actor.name} uses ${move.name}.`);
  }
  actor.tookTurn=true;if(st.log.length>20)st.log=st.log.slice(0,20);
  const next=st.party.find(p=>p.hp>0&&!p.tookTurn&&p.id!==actor.id);
  if(next){st.acting=next.id;}else{st.acting=null;setTimeout(enemyGroundTurn,350);}
  checkGroundCombatEnd();if(st.phase==='active')renderGroundCombat();
}
function enemyGroundTurn(){
  const st=groundCombatState;if(!st||st.phase!=='active')return;
  const aliveEnemies=st.enemies.filter(e=>e.hp>0&&!e.tookTurn);const aliveParty=st.party.filter(p=>p.hp>0);
  if(aliveEnemies.length&&aliveParty.length){
    aliveEnemies.forEach(e=>{
      if(e.status==='stunned'||e.disabled>0){if(e.disabled>0)e.disabled--;if(e.status==='stunned')e.status=null;st.log.unshift(`${e.name} is stunned — skips turn.`);e.tookTurn=true;return;}
      const tgt=aliveParty.sort((a,b)=>a.hp-b.hp)[0];const dmg=Math.max(1,Math.floor((e.atk||8)*(0.85+Math.random()*0.3)));
      // Check stealth
