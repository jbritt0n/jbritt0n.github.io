<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>VOID FRONTIER · FLEET EDITION v2</title>
<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --void:#0a0c10;--void2:#0d1117;--star:#e8f0ff;
  --nebula:#1a3a5a;--hazard:#c41e3a;--warn:#e67e22;
  --safe:#2ecc71;--alien:#8e44ad;--metal:#7f8c8d;
  --gold:#f1c40f;--cyan:#00e5ff;
  --border:rgba(0,229,255,0.22);--panel:#0d1117;
}
body{background:var(--void);color:var(--star);font-family:'VT323',monospace;font-size:18px;overflow:hidden;height:100vh;width:100vw;user-select:none}
#game{width:100vw;height:100vh;position:relative}
.screen{position:absolute;inset:0;display:none;flex-direction:column}
.screen.active{display:flex}
#title-screen{align-items:center;justify-content:center}
#sf-canvas{position:absolute;inset:0;z-index:0}
.title-wrap{position:relative;z-index:2;display:flex;flex-direction:column;align-items:center;gap:22px}
.logo{font-family:'Press Start 2P',monospace;font-size:clamp(28px,5vw,52px);color:var(--cyan);text-shadow:0 0 20px rgba(0,229,255,.9),0 0 60px rgba(0,229,255,.4);letter-spacing:6px;animation:logoPulse 3s ease-in-out infinite}
.logo-sub{font-family:'VT323',monospace;font-size:20px;color:var(--metal);letter-spacing:10px;margin-top:8px;text-align:center}
@keyframes logoPulse{0%,100%{text-shadow:0 0 20px rgba(0,229,255,.9),0 0 60px rgba(0,229,255,.4)}50%{text-shadow:0 0 40px rgba(0,229,255,1),0 0 100px rgba(0,229,255,.6)}}
.seed-box{background:var(--panel);border:1px solid var(--border);padding:28px 32px;display:flex;flex-direction:column;gap:14px;min-width:380px}
.seed-label{font-family:'Press Start 2P',monospace;font-size:9px;color:var(--cyan);letter-spacing:2px}
.seed-row{display:flex;gap:10px}
input,select{background:var(--void);border:1px solid var(--cyan);color:var(--star);font-family:'VT323',monospace;font-size:18px;padding:8px 12px;outline:none;width:100%}
.btn{background:transparent;border:1px solid var(--cyan);color:var(--cyan);font-family:'Press Start 2P',monospace;font-size:9px;padding:10px 15px;cursor:pointer;transition:all .15s;letter-spacing:1px;white-space:nowrap}
.btn:hover{background:var(--cyan);color:var(--void)}
.btn:disabled{opacity:.4;cursor:not-allowed;pointer-events:none}
.btn-gold{border-color:var(--gold);color:var(--gold)}.btn-gold:hover{background:var(--gold);color:var(--void)}
.btn-safe{border-color:var(--safe);color:var(--safe)}.btn-safe:hover{background:var(--safe);color:var(--void)}
.btn-warn{border-color:var(--warn);color:var(--warn)}.btn-warn:hover{background:var(--warn);color:var(--void)}
.btn-danger{border-color:var(--hazard);color:var(--hazard)}.btn-danger:hover{background:var(--hazard);color:#fff}
.btn-alien{border-color:var(--alien);color:var(--alien)}.btn-alien:hover{background:var(--alien);color:#fff}
.btn-sm{font-size:8px;padding:6px 10px}
.btn-full{width:100%}
#cc-screen{padding:16px 24px;gap:12px;overflow:hidden}
.cc-header{text-align:center;flex-shrink:0}
.cc-step-label{font-family:'Press Start 2P',monospace;font-size:12px;color:var(--cyan)}
.cc-step-desc{font-size:16px;color:var(--metal)}
.cc-progress{display:flex;gap:6px;justify-content:center;margin-top:8px}
.cc-pip{width:40px;height:4px;background:rgba(255,255,255,.1)}.cc-pip.done{background:var(--cyan)}.cc-pip.active{background:var(--gold)}
.opt-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;overflow-y:auto;flex:1;padding:4px 2px}
.opt-grid.cols-3{grid-template-columns:repeat(3,1fr)}
.opt-card{background:var(--panel);border:1px solid var(--border);padding:12px;cursor:pointer;transition:all .15s;display:flex;flex-direction:column;gap:6px;position:relative}
.opt-card:hover{border-color:var(--cyan);background:rgba(0,229,255,.04)}
.opt-card.selected{border-color:var(--gold);background:rgba(241,196,15,.07)}
.opt-card .oc-emoji{font-size:22px}.opt-card .oc-name{font-family:'Press Start 2P',monospace;font-size:8px;color:var(--star)}
.opt-card .oc-desc{font-size:13px;color:var(--metal)}.opt-card .oc-bonus{font-size:13px;color:var(--safe)}
.opt-card .oc-check{position:absolute;top:6px;right:8px;color:var(--gold);font-size:16px;display:none}
.opt-card.selected .oc-check{display:block}
.cc-nav{display:flex;justify-content:center;gap:14px;flex-shrink:0;margin-top:8px}
.name-step{display:flex;flex-direction:column;align-items:center;justify-content:center;flex:1;gap:28px}
.name-group{display:flex;flex-direction:column;gap:8px;width:340px}
.name-label{font-family:'Press Start 2P',monospace;font-size:8px;color:var(--metal)}
.dossier{background:var(--panel);border:1px solid var(--border);padding:20px;width:340px}
.dossier-title{font-family:'Press Start 2P',monospace;font-size:8px;color:var(--cyan);margin-bottom:10px}
.dossier-row{font-size:16px;color:var(--metal);line-height:2}.dossier-row span{color:var(--star)}
.hud{background:var(--panel);border-bottom:1px solid var(--border);padding:6px 14px;display:flex;align-items:center;gap:14px;flex-shrink:0;height:44px;overflow:hidden}
.hud-ship{font-family:'Press Start 2P',monospace;font-size:9px;color:var(--cyan);white-space:nowrap}
.stat{display:flex;align-items:center;gap:5px;flex-shrink:0}
.stat-lbl{font-size:12px;color:var(--metal);white-space:nowrap}
.bar-track{width:60px;height:7px;background:rgba(255,255,255,.08);flex-shrink:0}.bar-fill{height:100%}
.stat-val{font-size:14px;color:var(--star);white-space:nowrap;min-width:22px}
.hud-creds{margin-left:auto;font-family:'Press Start 2P',monospace;font-size:9px;color:var(--gold);white-space:nowrap}
.main-area{flex:1;display:flex;overflow:hidden}
.lp{width:210px;background:var(--panel);border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0}
.panel-hdr{font-family:'Press Start 2P',monospace;font-size:8px;color:var(--cyan);padding:9px 10px;border-bottom:1px solid var(--border);background:rgba(0,229,255,.04);display:flex;justify-content:space-between;align-items:center}
.lp-body{padding:10px;flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:6px;font-size:14px}
.lp-actions{padding:10px;border-top:1px solid var(--border);display:flex;flex-direction:column;gap:7px}
.rp{width:186px;background:var(--panel);border-left:1px solid var(--border);display:flex;flex-direction:column;overflow-y:auto;flex-shrink:0}
.rp-section{border-bottom:1px solid var(--border)}
.rp-toggle{cursor:pointer;user-select:none}
.collapse-btn{transition:transform 0.2s ease;display:inline-block;font-size:10px}
.rp-toggle.collapsed-header .collapse-btn{transform:rotate(-90deg)}
.rp-content{overflow-y:auto;max-height:160px}
.rp-content.collapsed{display:none}
.gc{flex:1;position:relative;overflow:hidden;background:#050709;min-width:200px}
#gx-canvas{display:block;image-rendering:pixelated;cursor:crosshair}
#sys-tooltip{position:absolute;background:var(--panel);border:1px solid var(--border);padding:4px 8px;font-size:13px;pointer-events:none;display:none;z-index:10;white-space:nowrap}
#ev-overlay{position:absolute;inset:0;background:rgba(0,0,0,.82);display:none;align-items:center;justify-content:center;z-index:50}
#ev-overlay.open{display:flex}
.ev-card{background:var(--panel);border:1px solid var(--cyan);padding:24px 28px;max-width:520px;width:90%;max-height:90vh;overflow-y:auto}
.ev-title{font-family:'Press Start 2P',monospace;font-size:11px;color:var(--gold);margin-bottom:10px}
.ev-body{font-size:17px;color:var(--star);line-height:1.6;margin:8px 0 12px}
.ev-choices{display:flex;flex-direction:column;gap:8px}
.choice-btn{background:transparent;border:1px solid var(--border);color:var(--star);font-family:'VT323',monospace;font-size:17px;padding:10px 14px;cursor:pointer;text-align:left;transition:all .1s}
.choice-btn:hover{border-color:var(--cyan);background:rgba(0,229,255,.08)}
.log-bar{background:var(--panel);border-top:1px solid var(--border);padding:6px 14px;height:72px;overflow:hidden;flex-shrink:0}
.log-hdr{font-family:'Press Start 2P',monospace;font-size:7px;color:var(--cyan);margin-bottom:4px}
.log-line{font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;line-height:1.4}
.rep-row{display:flex;justify-content:space-between;padding:4px 10px;font-size:13px;border-bottom:1px solid rgba(255,255,255,.04)}
.crew-row{display:flex;align-items:center;gap:8px;padding:5px 8px;border-bottom:1px solid rgba(255,255,255,.04)}
.crew-emoji{font-size:17px}.crew-info{display:flex;flex-direction:column}
.crew-name{font-size:13px;color:var(--star)}.crew-role{font-size:11px;color:var(--metal)}
.cap-info{padding:8px;font-size:13px;color:var(--metal)}
.tag{display:inline-block;padding:2px 5px;font-size:11px;border:1px solid;margin:2px 2px 0 0}
.st-header{background:var(--panel);border-bottom:1px solid var(--border);padding:8px 18px;display:flex;align-items:center;gap:18px;height:48px;flex-shrink:0}
.st-name{font-family:'Press Start 2P',monospace;font-size:10px;color:var(--cyan)}
.st-meta{font-size:15px;color:var(--metal);display:flex;gap:14px;flex:1}
.st-body{flex:1;display:flex;overflow:hidden}
.st-nav{width:190px;background:var(--panel);border-right:1px solid var(--border);overflow-y:auto;flex-shrink:0}
.st-node{padding:12px 10px;border-bottom:1px solid rgba(255,255,255,.05);cursor:pointer;display:flex;align-items:center;gap:8px}
.st-node:hover{background:rgba(0,229,255,.06)}.st-node.active{background:rgba(0,229,255,.09);border-left:3px solid var(--cyan)}
.st-node-emoji{font-size:20px}.st-node-name{font-family:'Press Start 2P',monospace;font-size:8px;color:var(--star)}
.st-content{flex:1;padding:16px;overflow-y:auto}
.st-content-hdr{font-family:'Press Start 2P',monospace;font-size:10px;color:var(--cyan);padding-bottom:8px;border-bottom:1px solid var(--border);margin-bottom:12px}
.st-footer{background:var(--panel);border-top:1px solid var(--border);padding:8px 18px;display:flex;justify-content:space-between;align-items:center;height:44px;flex-shrink:0}
.trade-row{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);padding:8px 12px;display:flex;align-items:center;gap:8px;margin-bottom:5px;flex-wrap:wrap}
.mod-card{background:var(--panel);border:1px solid var(--border);padding:12px;margin-bottom:8px}
.maint-row{display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid rgba(255,255,255,.05);font-size:15px}
.quest-item{background:rgba(0,229,255,.05);border:1px solid rgba(0,229,255,.15);padding:7px;margin-bottom:5px;font-size:13px}
.quest-hdr{font-family:'Press Start 2P',monospace;font-size:7px;color:var(--gold);margin-bottom:3px}
#combat-screen{flex-direction:column}
.cbat-hdr{background:var(--panel);border-bottom:1px solid var(--hazard);padding:8px 18px;display:flex;align-items:center;gap:16px;height:44px;flex-shrink:0}
.cbat-title{font-family:'Press Start 2P',monospace;font-size:9px;color:var(--hazard)}
.cbat-body{flex:1;display:flex;overflow:hidden}
.cbat-ship{width:240px;background:var(--panel);border-right:1px solid var(--border);padding:12px;overflow-y:auto;flex-shrink:0}
.cbat-ship.enemy-panel{border-right:none;border-left:1px solid var(--border)}
.cbat-center{flex:1;display:flex;flex-direction:column;background:var(--void);overflow:hidden}
.cbat-ship-name{font-family:'Press Start 2P',monospace;font-size:9px;margin-bottom:8px}
.cbat-bar-row{display:flex;align-items:center;gap:8px;font-size:14px;margin-bottom:5px}
.cbat-bar-lbl{width:42px;color:var(--metal);font-size:12px}.cbat-bar-track{flex:1;height:8px;background:rgba(255,255,255,.07)}.cbat-bar-fill{height:100%;transition:width 0.3s}
.sys-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:5px;margin-top:6px}
.sys-cell{border:1px solid rgba(255,255,255,.15);padding:6px 3px;text-align:center;font-size:12px}
.sys-cell.targetable{cursor:pointer;transition:border-color 0.1s}.sys-cell.targetable:hover{border-color:var(--warn)}
.sys-cell.targeted{border-color:var(--gold)!important;background:rgba(241,196,15,.1)}
.cbat-log{flex:1;overflow-y:auto;padding:12px;font-size:14px}
.cbat-log-entry{padding:3px 0;border-bottom:1px solid rgba(255,255,255,.04)}.cbat-log-entry.player{color:var(--cyan)}.cbat-log-entry.enemy{color:var(--hazard)}.cbat-log-entry.hazard{color:var(--warn)}.cbat-log-entry.system{color:var(--metal)}
.cbat-actions{background:var(--panel);border-top:1px solid var(--border);padding:10px 16px;display:flex;flex-direction:column;gap:7px;flex-shrink:0}
.station-panel{background:rgba(0,229,255,.04);border:1px solid rgba(0,229,255,.15);padding:7px;margin-top:8px}
.station-slot{display:flex;justify-content:space-between;align-items:center;padding:3px 0;font-size:12px;border-bottom:1px solid rgba(255,255,255,.05)}
.hazard-alert{background:rgba(230,126,34,.12);border:1px solid var(--warn);padding:6px 12px;font-size:13px;color:var(--warn);flex-shrink:0}
#ground-combat-screen{overflow-y:auto}
.gc-unit-card{border:1px solid var(--border);padding:8px;margin-bottom:6px;transition:all 0.1s ease}
.gc-unit-card.acting{box-shadow:0 0 0 2px var(--gold)}
.unit-sprite{width:36px;height:36px;margin:0 auto 5px;background:var(--panel);border-radius:3px;display:flex;align-items:center;justify-content:center;font-size:20px}
@keyframes flash{0%,100%{filter:brightness(1)}50%{filter:brightness(1.7)}}
@keyframes slideIn{from{transform:translateY(-10px);opacity:0}to{transform:translateY(0);opacity:1}}
#drama-overlay{position:fixed;inset:0;background:rgba(0,0,0,.80);display:none;align-items:center;justify-content:center;z-index:100}
#drama-overlay.open{display:flex}
.drama-card{background:var(--panel);border:1px solid var(--alien);padding:24px;max-width:480px;width:90%;max-height:90vh;overflow-y:auto;animation:slideIn 0.2s ease}
.drama-title{font-family:'Press Start 2P',monospace;font-size:10px;color:var(--alien);margin-bottom:10px}
#xeno-overlay{position:fixed;inset:0;background:rgba(0,0,0,.85);display:none;align-items:center;justify-content:center;z-index:90}
#xeno-overlay.open{display:flex}
.xeno-card{background:var(--panel);border:1px solid var(--alien);padding:24px;max-width:500px;width:90%;animation:slideIn 0.2s ease}
.xeno-alien-text{font-size:22px;color:var(--alien);letter-spacing:4px;margin:10px 0;min-height:30px;animation:xenoPulse 2s infinite}
@keyframes xenoPulse{0%,100%{opacity:1}50%{opacity:0.4}}
#gameover-overlay{position:fixed;inset:0;background:rgba(0,0,0,.93);display:none;align-items:center;justify-content:center;z-index:200}
#gameover-overlay.open{display:flex}
.go-card{background:var(--panel);border:1px solid var(--hazard);padding:36px;text-align:center;max-width:380px}
.go-title{font-family:'Press Start 2P',monospace;font-size:16px;color:var(--hazard);margin-bottom:16px}
.scanlines{position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,.04) 2px,rgba(0,0,0,.04) 4px);pointer-events:none;z-index:1000}
::-webkit-scrollbar{width:3px}::-webkit-scrollbar-track{background:var(--void)}::-webkit-scrollbar-thumb{background:var(--nebula)}
</style>
</head>
<body>
<div class="scanlines"></div>
<div id="game">

<div id="title-screen" class="screen active">
  <canvas id="sf-canvas"></canvas>
  <div class="title-wrap">
    <div><div class="logo">VOID FRONTIER</div><div class="logo-sub">FLEET EDITION v2</div></div>
    <div class="seed-box">
      <div class="seed-label">▸ MISSION SEED</div>
      <div class="seed-row" style="width:100%">
        <input type="text" id="seed-inp" placeholder="Enter seed..." maxlength="24" style="flex:1"/>
        <button class="btn btn-sm" onclick="randomSeed()" style="flex-shrink:0">⚡</button>
      </div>
      <div class="seed-label">▸ DIFFICULTY</div>
      <select id="difficulty-select">
        <option value="easy">EASY – More credits</option>
        <option value="normal" selected>NORMAL – Standard</option>
        <option value="hard">HARD – Scarcity</option>
      </select>
      <button class="btn btn-gold btn-full" onclick="beginGame()">▶ BEGIN MISSION</button>
      <button class="btn btn-sm btn-full" onclick="loadGamePrompt()" style="margin-top:4px">📂 LOAD SAVE</button>
    </div>
    <div style="font-size:13px;color:rgba(127,140,141,.6);text-align:center">Explore, fight, trade. Crew can die. Fleet expands.</div>
  </div>
</div>

<div id="cc-screen" class="screen">
  <div class="cc-header">
    <div class="cc-step-label" id="cc-title">CHOOSE YOUR ORIGIN</div>
    <div class="cc-step-desc" id="cc-desc">Step 1 of 5</div>
    <div class="cc-progress" id="cc-pips"></div>
  </div>
  <div id="cc-body" style="flex:1;overflow:hidden;display:flex;flex-direction:column;padding:0 10px"></div>
  <div class="cc-nav" id="cc-nav"></div>
</div>

<div id="galaxy-screen" class="screen">
  <div class="hud">
    <div class="hud-ship" id="hud-ship">VAGRANT STAR</div>
    <div class="stat"><div class="stat-lbl">HULL</div><div class="bar-track"><div class="bar-fill" id="b-hull" style="width:100%;background:var(--safe)"></div></div><div class="stat-val" id="v-hull">100</div></div>
    <div class="stat"><div class="stat-lbl">SHLD</div><div class="bar-track"><div class="bar-fill" id="b-shld" style="width:100%;background:var(--cyan)"></div></div><div class="stat-val" id="v-shld">50</div></div>
    <div class="stat"><div class="stat-lbl">FUEL</div><div class="bar-track"><div class="bar-fill" id="b-fuel" style="width:80%;background:var(--warn)"></div></div><div class="stat-val" id="v-fuel">80</div></div>
    <div class="stat"><div class="stat-lbl">MOR</div><div class="bar-track"><div class="bar-fill" id="b-mora" style="width:75%;background:var(--alien)"></div></div><div class="stat-val" id="v-mora">75</div></div>
    <div class="hud-creds" id="hud-creds">💰 1,000 CR</div>
    <button class="btn btn-sm" onclick="saveGame()" style="margin-left:8px;padding:4px 8px">💾</button>
  </div>
  <div class="main-area">
    <div class="lp">
      <div class="panel-hdr">◈ SYSTEM INTEL</div>
      <div class="lp-body" id="lp-body"></div>
      <div class="lp-actions" id="lp-actions"></div>
    </div>
    <div class="gc">
      <canvas id="gx-canvas"></canvas>
      <div id="sys-tooltip"></div>
      <div id="ev-overlay"><div class="ev-card">
        <div class="ev-title" id="ev-title"></div>
        <div class="ev-body" id="ev-body"></div>
        <div class="ev-choices" id="ev-choices"></div>
      </div></div>
    </div>
    <div class="rp" id="right-panel">
      <div class="rp-section"><div class="panel-hdr rp-toggle" onclick="toggleSection(this)">◈ REP <span class="collapse-btn">▼</span></div><div id="rp-rep" class="rp-content"></div></div>
      <div class="rp-section"><div class="panel-hdr rp-toggle" onclick="toggleSection(this)">◈ CARGO <span id="cargo-count" style="font-size:9px;color:var(--metal)"></span> <span class="collapse-btn">▼</span></div><div id="rp-cargo" class="rp-content"></div></div>
      <div class="rp-section"><div class="panel-hdr rp-toggle" onclick="toggleSection(this)">◈ QUESTS <span class="collapse-btn">▼</span></div><div id="rp-quests" class="rp-content" style="padding:8px"></div></div>
      <div class="rp-section"><div class="panel-hdr rp-toggle" onclick="toggleSection(this)">◈ CREW <span class="collapse-btn">▼</span></div><div id="rp-crew" class="rp-content"></div></div>
      <div class="rp-section"><div class="panel-hdr rp-toggle" onclick="toggleSection(this)">◈ CAPTAIN <span class="collapse-btn">▼</span></div><div id="rp-cap" class="cap-info rp-content"></div></div>
      <div class="rp-section"><div class="panel-hdr rp-toggle" onclick="toggleSection(this)">◈ FLEET <span class="collapse-btn">▼</span></div><div id="rp-fleet" class="rp-content" style="padding:8px"></div></div>
    </div>
  </div>
  <div class="log-bar"><div class="log-hdr">▸ CAPTAIN'S LOG</div><div id="log-list"></div></div>
</div>

<div id="station-screen" class="screen">
  <div class="st-header">
    <div class="st-name" id="st-name"></div>
    <div class="st-meta" id="st-meta"></div>
    <div id="st-credits" style="color:var(--gold);font-family:'Press Start 2P';font-size:9px"></div>
  </div>
  <div class="st-body">
    <div class="st-nav" id="st-nav"></div>
    <div class="st-content" id="st-content"></div>
  </div>
  <div class="st-footer">
    <button class="btn btn-warn" onclick="undock()">◀ UNDOCK</button>
    <div id="st-status" style="color:var(--metal);font-size:14px"></div>
  </div>
</div>

<div id="combat-screen" class="screen">
  <div class="cbat-hdr">
    <div class="cbat-title">⚔ SHIP COMBAT</div>
    <div style="flex:1"></div>
