// ===== TEXT PROCESSING =====
function processText(text){
  if(!text)return text;
  const alive=G.crew.filter(c=>c.alive);
  const c1=alive[0]?.name||'Crew Member';const c2=alive[1]?.name||'Crew Member';
  const sys=G.galaxy?.systems[G.curSys]?.name||'Unknown System';
  const fac=FACTIONS[Math.floor((G.rng?.next()||Math.random())*FACTIONS.length)]?.name||'Unknown Faction';
  return text.replace(/\{crew1\}/g,c1).replace(/\{crew2\}/g,c2).replace(/\{captain_name\}/g,G.captain.name||'Captain')
    .replace(/\{ship_name\}/g,G.flagship?.name||'Your Ship').replace(/\{system\}/g,sys).replace(/\{fac\}/g,fac)
    .replace(/\{crewMember\}/g,c1).replace(/\{alienSpecies\}/g,'Zyrathi').replace(/\{disposition\}/g,'cautiously friendly')
    .replace(/\{colonyName\}/g,'Colony Sigma-7').replace(/\{contrabandStatus\}/g,Math.random()<0.4?'nothing illegal':'contraband!');
}

