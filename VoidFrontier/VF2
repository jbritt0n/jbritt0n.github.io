  window._curXenoEnc=enc;
}
function resolveXenoChoice(i){
  document.getElementById('xeno-overlay').classList.remove('open');
  const enc=window._curXenoEnc;if(!enc)return;
  let ch=enc.choices[i],outcome=ch;
  if(ch.skillCheck){const{skill,dc}=ch.skillCheck;const roll=Math.floor(G.rng.next()*20)+(G.captain.skills[skill]||1);
    if(roll>=dc){outcome=ch.success||ch;addLog('Success!');G.captain.skills[skill]=Math.min(10,(G.captain.skills[skill]||1)+1);}
    else{outcome=ch.failure||{eff:{log:'Failed.'}};addLog('Failed.');}
  }
  const eff=outcome.eff||{};applyEff(eff);
  if(enc.xenoLang)G.xenoTranslations[enc.xenoLang]=Math.min(3,(G.xenoTranslations[enc.xenoLang]||0)+1);
  addLog(eff.log||'Encounter resolved.');updateHUD();updateRP();
  setTimeout(()=>{if(eff.combat)startCombat();else triggerEvent();},300);
}

// ===== DRAMA =====
function checkDrama(){
  const alive=G.crew.filter(c=>c.alive);if(alive.length<2)return triggerEvent();
  const ev=DRAMA_EVENTS[Math.floor(G.rng.next()*DRAMA_EVENTS.length)];
  const c1=alive[Math.floor(G.rng.next()*alive.length)],c2=alive.filter(c=>c!==c1)[0]||c1;
  window._curDrama={ev,c1,c2};
  document.getElementById('drama-title').textContent=ev.title;
  document.getElementById('drama-body').textContent=processText(ev.body).replace(/\{crew1\}/g,c1.name).replace(/\{crew2\}/g,c2.name);
  document.getElementById('drama-choices').innerHTML=ev.choices.map((c,i)=>`<button class="choice-btn" onclick="resolveDrama(${i})">${processText(c.text)}</button>`).join('');
  document.getElementById('drama-overlay').classList.add('open');
}
function resolveDrama(i){
  document.getElementById('drama-overlay').classList.remove('open');
  const d=window._curDrama;if(!d)return;
  let ch=d.ev.choices[i],outcome=ch;
  if(ch.skillCheck){const{skill,dc}=ch.skillCheck;const roll=Math.floor(G.rng.next()*20)+(G.captain.skills[skill]||1);
    if(roll>=dc){outcome=ch.success||ch;}else{outcome=ch.failure||{eff:{log:'Failed.'}};}}
  const e=outcome.eff||{};applyEff(e);if(e.crewTempLoss&&d.c1)d.c1.tempAway=3;
  addLog(e.log||'Drama resolved.');updateHUD();updateRP();setTimeout(triggerEvent,300);
}

// ===== EVENTS =====
function triggerEvent(){
  const sys=G.galaxy.systems[G.curSys];
  if(sys.danger>=4&&G.rng.next()<0.35){startCombat();return;}
  if(sys.danger>=2&&G.rng.next()<0.08){startCombat();return;}
  const ev=EVENTS[Math.floor(G.rng.next()*EVENTS.length)];if(!ev){addLog('Nothing unusual happens.');return;}
  currentEvent=ev;
  document.getElementById('ev-title').textContent=processText(ev.title);
  document.getElementById('ev-body').textContent=processText(ev.body);
  document.getElementById('ev-choices').innerHTML=ev.choices.map((c,i)=>`<button class="choice-btn" onclick="resolveChoice(${i})">${processText(c.text)}</button>`).join('');
  document.getElementById('ev-overlay').classList.add('open');
}
function resolveChoice(i){
  document.getElementById('ev-overlay').classList.remove('open');
  let ch=currentEvent.choices[i],outcome=ch;
  if(ch.skillCheck){const{skill,dc}=ch.skillCheck;const roll=Math.floor(G.rng.next()*20)+(G.captain.skills[skill]||1);
    if(roll>=dc){outcome=ch.success||ch;addLog(`Skill check: success!`);G.captain.skills[skill]=Math.min(10,(G.captain.skills[skill]||1)+1);G.captain.xp+=10;if(G.captain.xp>=G.captain.level*100){G.captain.level++;addLog(`Captain Lv.${G.captain.level}!`);}}
    else{outcome=ch.failure||{eff:{log:'Skill check failed.'}};addLog('Skill check failed.');}}
  const eff=outcome.eff||{};applyEff(eff);
  if(outcome.combat||eff.combat){startCombat();return;}
  if(eff.xenoEncounter){tryNonHostileEncounter();return;}
  if(outcome.followUp){currentEvent=outcome.followUp;document.getElementById('ev-title').textContent=processText(currentEvent.title);document.getElementById('ev-body').textContent=processText(currentEvent.body);document.getElementById('ev-choices').innerHTML=currentEvent.choices.map((c,idx)=>`<button class="choice-btn" onclick="resolveChoice(${idx})">${processText(c.text)}</button>`).join('');document.getElementById('ev-overlay').classList.add('open');return;}
  addLog(eff.log||'Event resolved.');updateHUD();updateLP();updateRP();
}

