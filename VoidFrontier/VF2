// ===== GALAXY GENERATION =====
function genGalaxy(rng,W,H){
  const NUM=40,MARGIN=55,MIN_D=64;const pos=[];let att=0;
  while(pos.length<NUM&&att<8000){att++;const x=MARGIN+rng.next()*(W-MARGIN*2),y=MARGIN+rng.next()*(H-MARGIN*2);if(!pos.some(p=>Math.hypot(p.x-x,p.y-y)<MIN_D))pos.push({x,y});}
  const systems=pos.map((p,i)=>{
    const st=STAR_TYPES[Math.floor(rng.next()*STAR_TYPES.length)],fac=FACTIONS[Math.floor(rng.next()*FACTIONS.length)];
    const f1=SYS_FEATURES[Math.floor(rng.next()*SYS_FEATURES.length)],f2=SYS_FEATURES[Math.floor(rng.next()*SYS_FEATURES.length)];
    const name=SYS_PFXS[Math.floor(rng.next()*SYS_PFXS.length)]+(rng.next()>.45?' '+SYS_SFXS[Math.floor(rng.next()*SYS_SFXS.length)]:'');
    const wealth=Math.floor(rng.next()*5)+1,danger=Math.floor(rng.next()*5)+1;
    const avail=ST_NODES.filter(n=>wealth>=(n.minWealth||1)&&!(n.requiresLowSecurity&&danger>3));
    const mods=[...avail].sort(()=>rng.next()-0.5).slice(0,Math.min(avail.length,4+Math.floor(wealth/2)));
    return{id:i,name,x:p.x,y:p.y,starType:st.type,starColor:st.color,faction:fac,features:[f1,f2].filter((v,i,a)=>a.indexOf(v)===i),danger,wealth,hasStation:true,stationType:wealth>=4?'Hub':'Outpost',hasPlanet:rng.next()>.35,visited:i===0,revealed:i===0,rx:0,ry:0,stationModules:mods};
  });
  const conns=[],cset=new Set();
  for(let i=0;i<systems.length;i++){
    const dists=[];for(let j=0;j<systems.length;j++){if(i===j)continue;const d=Math.hypot(systems[i].x-systems[j].x,systems[i].y-systems[j].y);if(d<165)dists.push({j,d});}
    dists.sort((a,b)=>a.d-b.d);dists.slice(0,Math.floor(rng.next()*3)+2).forEach(({j})=>{const k=Math.min(i,j)+'_'+Math.max(i,j);if(!cset.has(k)){cset.add(k);conns.push([i,j]);}});
  }
  return{systems,conns};
}
function reachable(){const r=new Set();G.galaxy.conns.forEach(([a,b])=>{if(a===G.curSys)r.add(b);if(b===G.curSys)r.add(a);});return r;}
function revealConnected(sysId){G.galaxy.systems[sysId].revealed=true;G.galaxy.conns.forEach(([a,b])=>{if(a===sysId)G.galaxy.systems[b].revealed=true;if(b===sysId)G.galaxy.systems[a].revealed=true;});}

// ===== MAP RENDERING =====
let gxCanvas,gxCtx,gxAniming=false;
function initGalaxy(){
  gxCanvas=document.getElementById('gx-canvas');gxCtx=gxCanvas.getContext('2d');
  const gc=document.querySelector('.gc');gxCanvas.width=gc.clientWidth||600;gxCanvas.height=gc.clientHeight||400;
  const sys=G.galaxy.systems;let x0=Infinity,x1=-Infinity,y0=Infinity,y1=-Infinity;
  sys.forEach(s=>{x0=Math.min(x0,s.x);x1=Math.max(x1,s.x);y0=Math.min(y0,s.y);y1=Math.max(y1,s.y);});
  const pad=52,scX=(gxCanvas.width-pad*2)/(x1-x0||1),scY=(gxCanvas.height-pad*2)/(y1-y0||1),sc=Math.min(scX,scY,.95);
  const ox=pad+(gxCanvas.width-pad*2-(x1-x0)*sc)/2-x0*sc,oy=pad+(gxCanvas.height-pad*2-(y1-y0)*sc)/2-y0*sc;
  sys.forEach(s=>{s.rx=Math.round(s.x*sc+ox);s.ry=Math.round(s.y*sc+oy);});
  gxCanvas.onclick=onGxClick;gxCanvas.onmousemove=onGxHover;gxCanvas.onmouseleave=()=>{document.getElementById('sys-tooltip').style.display='none';};
  const resizeObs=new ResizeObserver(()=>{gxCanvas.width=gc.clientWidth;gxCanvas.height=gc.clientHeight;initGalaxy();});resizeObs.observe(gc);
  gxAniming=true;drawGalaxy();
}
function drawGalaxy(){
  if(!gxAniming)return;const ctx=gxCtx,{systems,conns}=G.galaxy,W=gxCanvas.width,H=gxCanvas.height;
  ctx.fillStyle='#050709';ctx.fillRect(0,0,W,H);
  const reach=reachable();
  conns.forEach(([a,b])=>{const sa=systems[a],sb=systems[b];if(sa.revealed&&sb.revealed){ctx.beginPath();ctx.moveTo(sa.rx,sa.ry);ctx.lineTo(sb.rx,sb.ry);ctx.strokeStyle='rgba(0,229,255,.14)';ctx.lineWidth=1;ctx.stroke();}});
  systems.forEach((s,i)=>{
    const isCur=i===G.curSys,isSel=i===G.selSys,isReach=reach.has(i);if(!s.revealed&&!isReach&&!isCur)return;
    const r=isCur?7:5,cx=s.rx,cy=s.ry;
    if(s.revealed&&s.hasStation){ctx.beginPath();ctx.arc(cx,cy,r+4,0,Math.PI*2);ctx.strokeStyle='rgba(0,229,255,0.12)';ctx.lineWidth=1;ctx.stroke();}
    ctx.beginPath();ctx.arc(cx,cy,r,0,Math.PI*2);ctx.fillStyle=s.revealed?s.starColor:s.starColor+'55';ctx.fill();
    if(s.revealed){ctx.font='10px VT323';ctx.fillStyle='rgba(232,240,255,.72)';ctx.textAlign='center';ctx.fillText(s.name,cx,cy+r+13);}
    if(isCur){ctx.beginPath();ctx.arc(cx,cy,r+6,0,Math.PI*2);ctx.strokeStyle='#00e5ff';ctx.lineWidth=2;ctx.stroke();}
    if(isSel&&!isCur){ctx.beginPath();ctx.arc(cx,cy,r+5,0,Math.PI*2);ctx.strokeStyle='#f1c40f';ctx.lineWidth=1.5;ctx.stroke();}
    if(isReach&&!isCur&&!s.revealed){ctx.font='10px VT323';ctx.fillStyle='rgba(232,240,255,0.35)';ctx.textAlign='center';ctx.fillText('?',cx,cy+r+13);}
  });
  requestAnimationFrame(drawGalaxy);
}
function onGxClick(e){
  const rect=gxCanvas.getBoundingClientRect(),mx=e.clientX-rect.left,my=e.clientY-rect.top,reach=reachable();
  let best=null,bestD=20;G.galaxy.systems.forEach((s,i)=>{const d=Math.hypot(mx-s.rx,my-s.ry);if(d<bestD&&(s.revealed||reach.has(i)||i===G.curSys)){bestD=d;best=i;}});
  if(best!==null){G.selSys=best;updateLP();}
}
function onGxHover(e){
  const rect=gxCanvas.getBoundingClientRect(),mx=e.clientX-rect.left,my=e.clientY-rect.top,reach=reachable();
  const tt=document.getElementById('sys-tooltip');let found=false;
  G.galaxy.systems.forEach((s,i)=>{if(Math.hypot(mx-s.rx,my-s.ry)<12&&(s.revealed||reach.has(i)||i===G.curSys)){tt.textContent=s.revealed?`${s.name} — ${s.faction.name}`:`${s.name} — UNSCANNED`;tt.style.display='block';tt.style.left=(mx+14)+'px';tt.style.top=(my-10)+'px';found=true;}});
  if(!found)tt.style.display='none';
}

