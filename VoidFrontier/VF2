// ===== CARGO =====
function useCargoItem(id){
  const idx=G.cargo.findIndex(c=>c.id===id);if(idx<0)return;
  if(id==='fuel_cells'){G.flagship.fuel=Math.min(G.flagship.maxFuel,G.flagship.fuel+10);addLog('Fuel cell used. +10 fuel.');}
  else if(id==='medicine'){const v=G.crew.find(c=>c.alive&&c.hp<c.maxHp);if(v){v.hp=Math.min(v.maxHp,v.hp+15);addLog(`${v.name} healed 15 HP.`);}else addLog('No injured crew.');}
  else if(id==='protein_packs'){G.flagship.morale=Math.min(100,(G.flagship.morale||75)+4);addLog('Morale +4.');}
  else if(id==='artifacts'){G.flagship.maxHull+=5;G.flagship.hull=Math.min(G.flagship.maxHull,G.flagship.hull+5);addLog('Artifact analyzed. Hull capacity +5.');}
  else if(id==='dark_matter'){addLog('Dark Matter: Use at Data Exchange → Jump New Galaxy.');}
  else addLog(`${GOODS.find(g=>g.id===id)?.name||id} used.`);
  G.cargo[idx].qty--;if(G.cargo[idx].qty<=0)G.cargo.splice(idx,1);updateHUD();updateRP();
}

// ===== APPLY EFFECTS =====
function applyEff(eff){
  if(!eff)return;
  if(eff.cr)G.flagship.credits=Math.max(0,G.flagship.credits+eff.cr);
  if(eff.hull){G.flagship.hull=Math.min(G.flagship.maxHull,Math.max(1,G.flagship.hull+eff.hull));if(G.flagship.hull<=1)triggerGameOver();}
  if(eff.fuel)G.flagship.fuel=Math.min(G.flagship.maxFuel,Math.max(0,G.flagship.fuel+eff.fuel));
  if(eff.mora||eff.morale){const v=eff.mora||eff.morale;G.flagship.morale=Math.min(100,Math.max(0,(G.flagship.morale||75)+v));}
  if(eff.scrap)G.flagship.scrap=(G.flagship.scrap||0)+eff.scrap;
  if(eff.artifact)addCargo('artifacts',eff.artifact);
  if(eff.darkMatterChance&&G.rng.next()<eff.darkMatterChance){addCargo('dark_matter',1);addLog('Found Dark Matter shard!');}
  Object.keys(eff).forEach(k=>{if(k.startsWith('rep_')){const f=k.slice(4);G.rep[f]=(G.rep[f]||0)+eff[k];}});
  if(eff.crewGain){const nc=generateRandomCrew();G.crew.push(nc);addLog(`${nc.name} joins the crew!`);}
  if(eff.crewInjury){const alive=G.crew.filter(c=>c.alive);if(alive.length){const v=alive[Math.floor(G.rng.next()*alive.length)];v.hp=Math.max(1,v.hp-15);addLog(`${v.name} was injured.`);}}
  if(eff.questGenerate){const t=G.galaxy.systems[Math.floor(G.rng.next()*G.galaxy.systems.length)];if(t&&t.id!==G.curSys)addQuest({id:'q_'+Date.now(),title:'Guild Delivery',objective:'Deliver goods to system.',targetSysId:t.id,targetSysName:t.name,reward:{cr:eff.cr||500},type:'Delivery'});}
}

// ===== TRAVEL =====
function travelTo(id){
  if(G.fleet.some(s=>s.fuel<Math.ceil(10*s.fuelUse))){addLog('Not enough fuel!');return;}
  G.fleet.forEach(s=>s.fuel=Math.max(0,s.fuel-Math.ceil(10*s.fuelUse)));
  G.curSys=id;const sys=G.galaxy.systems[id];sys.visited=true;sys.revealed=true;revealConnected(id);G.selSys=id;G.jumps++;G.dramaTimer++;
  checkQuestCompletion(id);
  if(G.flagship.modules.includes('bio_hull'))G.flagship.hull=Math.min(G.flagship.maxHull,G.flagship.hull+Math.ceil(G.flagship.maxHull*0.01));
  if(G.flagship.modules.includes('void_drive')&&G.rng.next()<0.05){addLog('⚡ Void Drive glitch!');G.flagship.hull=Math.max(1,G.flagship.hull-5);}
  addLog(`Jumped to ${sys.name}. [${G.jumps} jumps]`);updateHUD();updateLP();updateRP();
  if(G.dramaTimer>=3&&G.crew.filter(c=>c.alive).length>=2){G.dramaTimer=0;setTimeout(checkDrama,800);}
  else setTimeout(()=>{if(!tryNonHostileEncounter())triggerEvent();},700);
}
function exploreSys(){
  const k='explored_'+G.curSys;const ct=G.probedFeatures[k]||0;
  if(ct>=2){addLog('Nothing more to explore here.');return;}
  G.probedFeatures[k]=ct+1;setTimeout(()=>{if(!tryNonHostileEncounter())triggerEvent();},400);
}
function tryNonHostileEncounter(){
  if(G.rng.next()>0.14)return false;
  const enc=NONHOSTILE_ENCOUNTERS[Math.floor(G.rng.next()*NONHOSTILE_ENCOUNTERS.length)];
  showXenoEncounter(enc);return true;
}

// ===== XENO ENCOUNTERS =====
function showXenoEncounter(enc){
  const lang=enc.xenoLang?XENO_LANGUAGES[enc.xenoLang]:null;
  document.getElementById('xeno-title').textContent=enc.title;
  document.getElementById('xeno-body').textContent=processText(enc.intro);
  document.getElementById('xeno-lang').textContent=lang?lang.greetings[Math.floor(Math.random()*lang.greetings.length)]:'';
  const tl=G.xenoTranslations[enc.xenoLang||'']||0;
  document.getElementById('xeno-translation').textContent=lang&&lang.translations[tl]?`[${lang.translations[tl]}]`:'';
  const bar=document.getElementById('xeno-translate-bar');
