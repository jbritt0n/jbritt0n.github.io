function applyCharacterBonuses(){
  const origin=ORIGINS.find(o=>o.id===G.captain.origin);
  if(origin?.effect){const e=origin.effect;
    if(e.maxHullBonus){G.flagship.maxHull+=e.maxHullBonus;G.flagship.hull=G.flagship.maxHull;}
    if(e.tradeSellMult)G.flagship.tradeSellMult=(G.flagship.tradeSellMult||1)*e.tradeSellMult;
    if(e.blackMarketAccess)G.flagship.blackMarketAccess=true;
    if(e.startingModule&&!G.flagship.modules.includes(e.startingModule))G.flagship.modules.push(e.startingModule);
    if(e.diplomacyBonus)G.captain.skills.charisma+=e.diplomacyBonus;
    if(e.alienSocialBonus)G.captain.skills.charisma+=e.alienSocialBonus;
    if(e.repGainMult)G.flagship.repGainMult=(G.flagship.repGainMult||1)*e.repGainMult;
    if(e.scrapYieldMult)G.flagship.scrapYieldMult=(G.flagship.scrapYieldMult||1)*e.scrapYieldMult;
    if(e.crewXpGainMult)G.flagship.crewXpGainMult=(G.flagship.crewXpGainMult||1)*e.crewXpGainMult;
  }
  if(origin?.startingRep)Object.entries(origin.startingRep).forEach(([f,v])=>{G.rep[f]=(G.rep[f]||0)+v;});
  const job=JOBS.find(j=>j.id===G.captain.job);
  if(job?.jobEffect){const e=job.jobEffect;
    if(e.repGainMult)G.flagship.repGainMult=(G.flagship.repGainMult||1)*e.repGainMult;
    if(e.scrapYieldMult)G.flagship.scrapYieldMult=(G.flagship.scrapYieldMult||1)*e.scrapYieldMult;
    if(e.hiddenCargoModule&&!G.flagship.modules.includes('cargo_expander'))G.flagship.modules.push('cargo_expander');
    if(e.boardingStrengthBonus)G.galaxyFlags.boardingStrengthBonus=e.boardingStrengthBonus;
    if(e.highlightRuins)G.galaxyFlags.highlightRuins=true;
    if(e.miningYieldMult)G.flagship.miningYieldMult=e.miningYieldMult;
    if(e.noRepLossVsPirates)G.galaxyFlags.noRepLossVsPirates=true;
  }
}

