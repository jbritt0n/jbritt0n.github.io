    el.innerHTML=`<div class="st-content-hdr">🛐 VOID SHRINE</div><div style="font-size:15px;color:var(--metal);margin-bottom:14px;line-height:1.6">The shrine hums with ancient energy. Silence falls over your crew.</div><button class="btn btn-sm btn-safe" onclick="shrineBless()">🙏 RECEIVE BLESSING (Free)</button><div class="maint-row" style="margin-top:10px"><span>Generous offering (+10 morale)</span><button class="btn btn-sm" onclick="donateShrine()">DONATE 200CR</button></div><div style="margin-top:14px;color:var(--metal);font-size:14px" id="shrine-result"></div>`;
  }else if(nodeId==='gambling'){
    el.innerHTML=`<div class="st-content-hdr">🎲 GAMBLING DEN</div><div style="color:var(--metal);font-size:14px;margin-bottom:12px">House edge: ~10%. Fortune favours the bold.</div><div style="display:flex;gap:8px;flex-wrap:wrap"><button class="btn btn-sm" onclick="gamble(100)" ${G.flagship.credits<100?'disabled':''}>BET 100CR</button><button class="btn btn-sm" onclick="gamble(500)" ${G.flagship.credits<500?'disabled':''}>BET 500CR</button><button class="btn btn-sm btn-gold" onclick="gamble(1000)" ${G.flagship.credits<1000?'disabled':''}>BET 1000CR</button><button class="btn btn-sm btn-danger" onclick="gamble(3000)" ${G.flagship.credits<3000?'disabled':''}>HIGH STAKES 3000CR</button></div><div id="gamble-result" style="margin-top:12px;font-size:16px;min-height:24px"></div>`;
  }else if(nodeId==='armory'){
    el.innerHTML=`<div class="st-content-hdr">🔫 ARMORY</div><div style="color:var(--metal);font-size:13px;margin-bottom:8px">Weapons boost crew ATK in ground combat.</div><div class="trade-row"><span>🔫 Combat Sidearm (+3 ATK)</span><button class="btn btn-sm" onclick="buyWeapon('sidearm',200)" ${G.flagship.credits<200?'disabled':''}>200CR</button></div><div class="trade-row"><span>⚔ Combat Blade (+5 ATK, melee)</span><button class="btn btn-sm" onclick="buyWeapon('blade',350)" ${G.flagship.credits<350?'disabled':''}>350CR</button></div><div class="trade-row"><span>🎯 Sniper Rifle (+8 ATK, ranged)</span><button class="btn btn-sm" onclick="buyWeapon('sniper',600)" ${G.flagship.credits<600?'disabled':''}>600CR</button></div><div class="trade-row"><span>💥 Plasma Caster (+12 ATK, energy)</span><button class="btn btn-sm btn-warn" onclick="buyWeapon('plasma',1200)" ${G.flagship.credits<1200?'disabled':''}>1200CR</button></div><div style="margin-top:12px;font-family:'Press Start 2P';font-size:7px;color:var(--cyan)">EQUIP TO CREW</div>${G.crew.filter(c=>c.alive).map(c=>`<div class="trade-row" style="font-size:13px"><span>${c.emoji} ${c.name} | Weapon: ${c.equippedWeapon||'None'}</span><button class="btn btn-sm" onclick="equipWeaponToCrew('${c.id}')">EQUIP</button></div>`).join('')}`;
  }else if(nodeId==='embassy'){
    el.innerHTML=`<div class="st-content-hdr">🏛️ ${sys.faction.name.toUpperCase()} EMBASSY</div><div style="font-size:15px;color:var(--metal);margin-bottom:12px;line-height:1.6">The Embassy can improve your standing with ${sys.faction.name}.</div><div class="maint-row"><span>Donate for goodwill</span><button class="btn btn-sm" onclick="embassyDonate(500)">DONATE 500CR (+10 Rep)</button></div><div class="maint-row"><span>Current Rep: ${G.rep[sys.faction.id]||0}</span></div><div class="maint-row"><span>Accept diplomatic mission</span><button class="btn btn-sm" onclick="embassyMission()">REQUEST MISSION</button></div><div style="margin-top:10px;color:var(--metal);font-size:13px">Improving rep opens new mission types and dialogue options.</div>`;
  }else{
    el.innerHTML=`<div class="st-content-hdr">${nodeId.toUpperCase()}</div><div style="color:var(--metal)">Station service available.</div>`;
  }
}

// ===== STATION ACTIONS =====
function hireCrew(id){const c=window._tempHirePool?.find(x=>x.id===id);if(!c||G.flagship.credits<c.cost){addLog('Cannot hire.');return;}G.flagship.credits-=c.cost;G.crew.push({...c,id:'c'+Math.random().toString(36).slice(2)});addLog(`Hired ${c.name}.`);updateHUD();updateRP();renderNodeContent('cantina');}
function talkBartender(){addLog('Bartender: "Word is the Syndicate\'s hiring. Credits up front."');G.flagship.morale=Math.min(100,(G.flagship.morale||75)+2);updateHUD();}
function buyRumor(i){if(G.flagship.credits<150){addLog('Not enough credits.');return;}G.flagship.credits-=150;addLog('Rumor purchased.');updateHUD();}
function stDrink(){if(G.flagship.credits<50){addLog('Not enough credits.');return;}G.flagship.credits-=50;G.flagship.morale=Math.min(100,(G.flagship.morale||75)+8);addLog('Drinks purchased. Morale +8.');updateHUD();}
function repairHull(){const miss=G.flagship.maxHull-G.flagship.hull;if(miss<=0){addLog('Hull already at max.');return;}const cost=Math.ceil(miss*6*(G.flagship.repairCostMult||1));if(G.flagship.credits<cost){addLog(`Need ${cost} CR.`);return;}G.flagship.credits-=cost;G.flagship.hull=G.flagship.maxHull;addLog(`Hull fully repaired. -${cost} CR.`);updateHUD();renderNodeContent('maintenance');}
function refuel(){const miss=G.flagship.maxFuel-G.flagship.fuel;if(miss<=0){addLog('Fuel already full.');return;}const cost=Math.ceil(miss*4);if(G.flagship.credits<cost){addLog(`Need ${cost} CR.`);return;}G.flagship.credits-=cost;G.flagship.fuel=G.flagship.maxFuel;addLog(`Fuel topped up. -${cost} CR.`);updateHUD();renderNodeContent('maintenance');}
function buyModule(id){const m=MODULES.find(x=>x.id===id);if(!m){return;}if(G.flagship.credits<m.cost){addLog('Not enough credits.');return;}if(G.flagship.modules.length>=G.flagship.moduleSlots){addLog(`Module bay full! (${G.flagship.modules.length}/${G.flagship.moduleSlots})`);return;}G.flagship.credits-=m.cost;G.flagship.modules.push(m.id);// Apply passive effects
if(m.effect==='hull'){G.flagship.maxHull=Math.floor(G.flagship.maxHull*1.2);G.flagship.hull=Math.floor(G.flagship.hull*1.2);}
else if(m.effect==='cargo')G.flagship.cargoMax+=10;
else if(m.effect==='fuel_saver')G.flagship.fuelUse=Math.max(0.1,G.flagship.fuelUse*0.6);
addLog(`Installed ${m.name}.`);updateHUD();updateRP();renderNodeContent('maintenance');}
function sellModule(mid){const idx=G.flagship.modules.indexOf(mid);if(idx<0)return;const m=MODULES.find(x=>x.id===mid);if(!m)return;const sp=Math.floor(m.cost*0.6);G.flagship.modules.splice(idx,1);G.flagship.credits+=sp;// Undo passive effects
if(m.effect==='cargo')G.flagship.cargoMax=Math.max(4,G.flagship.cargoMax-10);
addLog(`Sold ${m.name} for ${sp} CR.`);updateHUD();updateRP();renderNodeContent('maintenance');}
function buyGood(id){const p=stationPrice(id,G.curSys,true);if(G.flagship.credits<p){addLog('Not enough credits.');return;}if(!canAddCargo(id)){addLog('Cargo full!');return;}G.flagship.credits-=p;addCargo(id);updateHUD();updateRP();renderNodeContent('market');}
function sellGood(id){const p=stationPrice(id,G.curSys,false);const idx=G.cargo.findIndex(c=>c.id===id);if(idx<0)return;G.flagship.credits+=p;G.cargo[idx].qty--;if(G.cargo[idx].qty<=0)G.cargo.splice(idx,1);addLog(`Sold ${GOODS.find(g=>g.id===id)?.name||id} for ${p} CR.`);updateHUD();updateRP();renderNodeContent('market');}
function buyGoodIllegal(id){const p=Math.round(stationPrice(id,G.curSys,true)*1.4);if(G.flagship.credits<p){addLog('Not enough credits.');return;}if(!canAddCargo(id)){addLog('Cargo full!');return;}G.flagship.credits-=p;addCargo(id);const fac=G.galaxy.systems[G.curSys].faction.id;G.rep[fac]=Math.max(-100,(G.rep[fac]||0)-5);addLog(`Bought illegal goods. ${fac} rep -5.`);updateHUD();updateRP();}
function acceptContract(id){const c=G.availableContracts?.find(x=>x.id===id);if(!c){addLog('Contract not found.');return;}const ac=G.activeQuests.filter(qid=>!G.contracts.find(x=>x.id===qid)?.completed).length;if(ac>=MAX_ACTIVE_QUESTS){addLog('Quest limit reached.');return;}if(!G.contracts)G.contracts=[];G.contracts.push({...c});G.activeQuests.push(id);addLog(`✅ Accepted: ${c.title}`);renderNodeContent('guild');updateRP();}
function sellExploData(){const unsold=G.galaxy.systems.filter(s=>s.visited&&!G.soldExplorationData.includes(s.id));const pay=unsold.length*80;G.flagship.credits+=pay;unsold.forEach(s=>G.soldExplorationData.push(s.id));addLog(`Sold exploration data for ${pay} CR.`);updateHUD();renderNodeContent('dataexchange');}
function jumpNewGalaxy(){const idx=G.cargo.findIndex(c=>c.id==='dark_matter');const dm=idx>=0?G.cargo[idx].qty:0;if(dm<5){addLog(`Need 5 Dark Matter. Have ${dm}.`);return;}G.cargo[idx].qty-=5;if(G.cargo[idx].qty<=0)G.cargo.splice(idx,1);const ns=hashStr(G.seed+'_next')|0;initState(ns.toString(),G.difficulty);launchGame();addLog('Jumped to new galaxy! 5 Dark Matter consumed.');}
function shrineBless(){const bl=['+5 Max Hull','Shields +20','Fuel +20','Morale +10','Crew healed'];const b=bl[Math.floor(Math.random()*bl.length)];if(b.includes('Hull')){G.flagship.maxHull+=5;G.flagship.hull+=5;}else if(b.includes('Shield')){G.flagship.shields=Math.min(G.flagship.maxShields,G.flagship.shields+20);}else if(b.includes('Fuel')){G.flagship.fuel=Math.min(G.flagship.maxFuel,G.flagship.fuel+20);}else if(b.includes('Morale')){G.flagship.morale=Math.min(100,(G.flagship.morale||75)+10);}else{G.crew.filter(c=>c.alive).forEach(c=>{c.hp=Math.min(c.maxHp,c.hp+10);});}const r=document.getElementById('shrine-result');if(r)r.textContent=`Blessing: ${b}`;addLog(`Shrine blessing: ${b}.`);updateHUD();updateRP();}
function donateShrine(){if(G.flagship.credits<200){addLog('Need 200 CR.');return;}G.flagship.credits-=200;G.flagship.morale=Math.min(100,(G.flagship.morale||75)+10);addLog('Donated 200 CR to the shrine. Morale +10.');updateHUD();}
function gamble(amount){if(G.flagship.credits<amount){addLog('Not enough credits.');return;}G.flagship.credits-=amount;const win=G.rng.next()<0.45;const r=document.getElementById('gamble-result');if(win){const winnings=Math.floor(amount*(1.5+G.rng.next()));G.flagship.credits+=winnings;addLog(`You won ${winnings} CR!`);if(r)r.innerHTML=`<span style="color:var(--safe)">WIN! +${winnings} CR</span>`;}else{addLog(`Lost ${amount} CR.`);if(r)r.innerHTML=`<span style="color:var(--hazard)">LOSS. -${amount} CR</span>`;}updateHUD();}
function embassyDonate(amount){if(G.flagship.credits<amount){addLog('Not enough credits.');return;}G.flagship.credits-=amount;const fac=G.galaxy.systems[G.curSys].faction.id;G.rep[fac]=(G.rep[fac]||0)+10;addLog(`Donated ${amount} CR. ${fac} rep +10.`);updateHUD();updateRP();}
function embassyMission(){const sys=G.galaxy.systems[G.curSys];addQuest({id:'q_embassy_'+Date.now(),title:`${sys.faction.name} Mission`,objective:`Complete a diplomatic task for ${sys.faction.name}.`,targetSysId:sys.id,targetSysName:sys.name,reward:{cr:700,rep:{[sys.faction.id]:15}},type:'Diplomatic'});renderNodeContent('embassy');}
function buyWeapon(type,cost){if(G.flagship.credits<cost){addLog('Not enough credits.');return;}G.flagship.credits-=cost;const wepNames={sidearm:'Combat Sidearm',blade:'Combat Blade',sniper:'Sniper Rifle',plasma:'Plasma Caster'};const wepAtk={sidearm:3,blade:5,sniper:8,plasma:12};addCargo('small_arms',1);window._lastBoughtWeapon={type,name:wepNames[type],atkBonus:wepAtk[type]};addLog(`Bought ${wepNames[type]}.`);updateHUD();renderNodeContent('armory');}
function equipWeaponToCrew(crewId){const w=window._lastBoughtWeapon;if(!w){addLog('No weapon in hand. Buy one first.');return;}const c=G.crew.find(x=>x.id===crewId);if(!c)return;if(c.equippedWeapon){addLog(`${c.name} already has a weapon equipped.`);return;}c.equippedWeapon=w.name;c.atk+=w.atkBonus;window._lastBoughtWeapon=null;addLog(`${c.name} equipped ${w.name}. ATK +${w.atkBonus}.`);updateRP();renderNodeContent('armory');}
function undock(){addLog('Undocked.');showScreen('galaxy-screen');updateHUD();updateLP();updateRP();}
function triggerGameOver(){document.getElementById('go-sub').textContent=`Fell in the ${G.galaxy.systems[G.curSys].name} system.`;document.getElementById('go-stats').innerHTML=`Jumps: ${G.jumps}<br>Credits: ${G.flagship.credits.toLocaleString()} CR<br>Crew survived: ${G.crew.filter(c=>c.alive).length}<br>Seed: ${G.seed}`;document.getElementById('gameover-overlay').classList.add('open');}

// ===== BOOT =====
window.addEventListener('load',()=>{initState(rndSeedStr());document.getElementById('seed-inp').value=G.seed;showScreen('title-screen');initStarfield();});
</script></body></html>
