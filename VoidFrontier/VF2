function addCombatLog(msg,type='system'){G.combat.log.unshift({msg,type});const el=document.getElementById('cbat-log');el.innerHTML=G.combat.log.slice(0,25).map(e=>`<div class="cbat-log-entry ${e.type}">${e.msg}</div>`).join('');}
