function stationPrice(id,sysIdx,buying){
  const g=GOODS.find(x=>x.id===id);if(!g)return 0;
  const r=new RNG(hashStr(G.seed)+sysIdx*137+id.charCodeAt(0)*17);const v=0.85+r.next()*0.30;const w=0.6+G.galaxy.systems[sysIdx].wealth*0.18;
  let p=Math.round(g.basePrice*w*v);if(buying)p=Math.round(p*1.18);else p=Math.round(p*(G.flagship.tradeSellMult||1.0));return Math.max(1,p);
}
function stationGoods(sysIdx){const r=new RNG(hashStr(G.seed)+sysIdx*251);return GOODS.filter(g=>g.legal).sort(()=>r.next()-.5).slice(0,6);}
function stationRumors(sysIdx){const r=new RNG(hashStr(G.seed)+sysIdx*421);return [...RUMOR_POOL].sort(()=>r.next()-.5).slice(0,3).map(t=>t.replace('{sys}',G.galaxy.systems[sysIdx].name).replace('{fac}',FACTIONS[Math.floor(r.next()*FACTIONS.length)].name));}
function generateHireableCrew(sysIdx){
  const r=new RNG(hashStr(G.seed)+sysIdx*739+11);const hired=G.crew.map(c=>c.name);const fn=['Kael','Lyra','Dax','Nova','Orin','Vex','Zane','Yara','Jax','Mira','Rex','Sia','Talon','Vega','Wren'];const ln=['Kas','Tong','Varley','Nox','Thorn','Chen','Rook','Silas','Frost','Steel','Vance','Cross','Blade','Ward','Moon'];
  const ROLES=[{id:'Gunner',emoji:'🔫',hp:[40,60],atk:[10,16],spd:[3,6],skill:[4,7],base:350},{id:'Technician',emoji:'🔧',hp:[35,50],atk:[5,9],spd:[4,7],skill:[7,11],base:300},{id:'Medic',emoji:'💉',hp:[30,45],atk:[4,8],spd:[4,7],skill:[8,12],base:400},{id:'Scout',emoji:'🔍',hp:[30,45],atk:[7,11],spd:[7,11],skill:[6,10],base:320},{id:'Pilot',emoji:'🚀',hp:[35,50],atk:[5,9],spd:[8,12],skill:[7,11],base:450}];
  const out=[];let att=0;
  while(out.length<2&&att<60){att++;const name=`${fn[Math.floor(r.next()*fn.length)]} ${ln[Math.floor(r.next()*ln.length)]}`;if(hired.includes(name))continue;const role=ROLES[Math.floor(r.next()*ROLES.length)];const ri=(a,b)=>Math.floor(r.next()*(b-a+1))+a;const hp=ri(...role.hp),atk=ri(...role.atk),spd=ri(...role.spd),skill=ri(...role.skill);const cost=Math.floor(role.base+(atk+skill)*10+r.next()*150);out.push({id:`hire_${sysIdx}_${att}`,name,role:role.id,emoji:role.emoji,hp,maxHp:hp,atk,spd,skill,cost,loyalty:50+ri(0,20),alive:true,xp:0,level:1,equippedWeapon:null,species:'Human',bio:`${role.id} seeking work.`,classTier:1,advancedClass:null,ap:4,maxAp:4});}
  window._tempHirePool=out;return out;
}
function generateModuleInventory(){
  const r=new RNG(hashStr(G.seed)+G.curSys*1123+77);const rw={common:60,uncommon:30,rare:15,legendary:5,mythic:1};
  const pool=[...MODULES].map(m=>({...m,w:rw[m.rarity]||20*(1+G.jumps/20)}));const sel=[];const wp=[...pool];
  for(let i=0;i<4&&wp.length;i++){const tot=wp.reduce((s,m)=>s+m.w,0);let rr=r.next()*tot;for(let j=0;j<wp.length;j++){rr-=wp[j].w;if(rr<=0){sel.push(wp[j]);wp.splice(j,1);break;}}}
  return sel;
}

