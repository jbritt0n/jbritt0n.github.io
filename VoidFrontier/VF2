function addQuest(q){
  if(G.activeQuests.length>=MAX_ACTIVE_QUESTS){addLog('Quest log full!');return;}
  const id=q.id||'q_'+Date.now();if(G.contracts.find(c=>c.id===id&&!c.completed))return;
  const quest={id,title:q.title||'Contract',objective:q.objective||'Complete the task.',targetSysId:q.targetSysId||null,targetSysName:q.targetSysName||'Unknown',reward:q.reward||{cr:400},completed:false,type:q.type||'Generic'};
  G.contracts.push(quest);G.activeQuests.push(id);updateRP();addLog(`📜 Quest: ${quest.title}`);
}
function checkQuestCompletion(sysId){
  let anyDone=false;
  G.activeQuests.forEach(qid=>{
    const q=G.contracts.find(c=>c.id===qid);if(!q||q.completed)return;
    if(q.targetSysId===sysId||q.targetSysName===G.galaxy.systems[sysId]?.name){
      q.completed=true;const r=q.reward||{};
      if(r.cr){G.flagship.credits+=r.cr;addLog(`✅ Quest Complete: ${q.title}! +${r.cr} CR`);}
      if(r.rep)Object.entries(r.rep).forEach(([f,v])=>{G.rep[f]=(G.rep[f]||0)+v;});
      anyDone=true;
    }
  });
  if(anyDone){G.activeQuests=G.activeQuests.filter(qid=>{const q=G.contracts.find(c=>c.id===qid);return q&&!q.completed;});updateHUD();updateRP();}
}
function genContracts(){
  const out=[];const count=2+Math.floor(G.rng.next()*3);
  for(let i=0;i<count;i++){
    const sys=G.galaxy.systems[Math.floor(G.rng.next()*G.galaxy.systems.length)];if(sys.id===G.curSys)continue;
    const types=['Delivery','Escort','Bounty','Recon','Salvage'];const type=types[Math.floor(G.rng.next()*types.length)];
    const reward=400+Math.floor(G.rng.next()*600)+(sys.wealth*50);
    out.push({id:`q_${Date.now()}_${i}`,title:`${type} Contract`,desc:`${type} mission to ${sys.name}.`,targetSysId:sys.id,targetSysName:sys.name,reward,accepted:false,completed:false,type});
  }
  return out;
}

