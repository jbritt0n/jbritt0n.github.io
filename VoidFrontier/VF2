      tgt.hp=Math.max(0,tgt.hp-dmg);st.log.unshift(`${e.name} attacks ${tgt.name} for ${dmg}!`);e.tookTurn=true;
    });
  }
  // Start new round
  st.round++;document.getElementById('gc-round-display').textContent=`Round ${st.round}`;
  st.party.forEach(p=>{p.tookTurn=false;if(p.hp>0){p.ap=p.maxAp||4;}});
