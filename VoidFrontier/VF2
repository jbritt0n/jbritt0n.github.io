function groundFlee(){
  const st=groundCombatState;if(!st)return;
  const ps=st.party.reduce((s,p)=>s+(p.spd||5),0)/Math.max(1,st.party.length);
  const es=st.enemies.filter(e=>e.hp>0).reduce((s,e)=>s+(e.spd||5),0)/Math.max(1,st.enemies.filter(e=>e.hp>0).length);
  const ch=0.45+Math.max(0,ps-es)*0.04;
  if(Math.random()<ch){st.phase='fled';st.log.unshift('Tactical retreat!');renderGroundCombat();setTimeout(closeGroundCombat,900);}
  else{st.log.unshift('Retreat failed! Enemies counterattack!');st.enemies.filter(e=>e.hp>0).forEach(e=>{const t=st.party.find(p=>p.hp>0);if(t){const d=Math.floor((e.atk||8)*1.2);t.hp=Math.max(0,t.hp-d);st.log.unshift(`${e.name} hits ${t.name} for ${d}!`);}});checkGroundCombatEnd();renderGroundCombat();}
}
