function canAddCargo(id,qty=1){const g=GOODS.find(x=>x.id===id);if(!g)return false;const w=G.cargo.reduce((s,c)=>s+(GOODS.find(x=>x.id===c.id)?.wt||1)*c.qty,0);return(w+g.wt*qty)<=G.totalCargoCap;}
function addCargo(id,qty=1){if(!canAddCargo(id,qty)){addLog('Cargo hold full!');return false;}const ex=G.cargo.find(c=>c.id===id);if(ex)ex.qty+=qty;else G.cargo.push({id,qty});return true;}
function generateRandomCrew(){const b=CREW_POOL[Math.floor(G.rng.next()*CREW_POOL.length)];return{...b,id:'c'+Math.random().toString(36).slice(2),alive:true,hp:b.maxHp,xp:0,level:1,equippedWeapon:null,classTier:1,advancedClass:null,ap:4,maxAp:4};}
function rollShip(tmpl){
  const r=new RNG(hashStr(G.seed)+tmpl.id.charCodeAt(0)*17);
  const ri=(a,b)=>Math.floor(r.next()*(b-a+1))+a;
  return{hull:ri(...tmpl.statRanges.hull),shields:ri(...tmpl.statRanges.shields),cargo:ri(...tmpl.statRanges.cargo),fuelUse:+(ri(tmpl.statRanges.fuelUse[0]*10,tmpl.statRanges.fuelUse[1]*10)/10).toFixed(1),moduleSlots:ri(...tmpl.statRanges.moduleSlots),crewMax:ri(...tmpl.statRanges.crewMax)};
}

