function interactFeature(feature){
  if(G.selSys!==G.curSys){addLog('Travel to this system first.');return;}
  const key=`${G.curSys}_${feature}`;if(G.probedFeatures[key]){addLog('Already probed.');return;}
  let outcomes=PROBE_OUTCOMES.default;
  for(const[kw,list]of Object.entries(PROBE_OUTCOMES)){if(feature.toLowerCase().includes(kw.toLowerCase())){outcomes=list;break;}}
  let sel=null;let cum=0;const roll=G.rng.next();
  for(const o of outcomes){const c=o.chance??(1.0/outcomes.length);cum+=c;if(roll<cum||Math.abs(cum-1.0)<0.001){sel=o;break;}}
  if(!sel)sel=outcomes[0];G.probedFeatures[key]=true;
  const eff=sel.eff||{};let msg=sel.text;
  applyEff(eff);if(eff.shrineBless)shrineBless();
  if(eff.combat){addLog(msg);startCombat();updateHUD();updateRP();updateLP();return;}
  if(eff.groundCombat){addLog(msg);startGroundCombat({feature});updateHUD();updateRP();updateLP();return;}
  if(eff.dock){addLog(msg);dockStation();return;}
  addLog(msg);updateHUD();updateRP();updateLP();
}

